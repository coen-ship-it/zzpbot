# ZZPbot Environment Variables
# Kopieer dit bestand naar .env en vul je eigen waarden in

# === OPENROUTER API ===
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model voor analyse (development: haiku, productie: sonnet)
OPENROUTER_MODEL=anthropic/claude-3-5-haiku

# === SERVER CONFIGURATIE ===
# Volledige URL van je server (voor monitor config downloads)
SERVER_URL=https://jouw-app.railway.app

# Flask secret key (genereer met: python -c "import secrets; print(secrets.token_hex())")
SECRET_KEY=jouw-geheime-sleutel-hier

# === EMAIL (optioneel) ===
# SMTP voor doorsturen van rapport naar founder + NextEnabler
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jouw@email.com
SMTP_PASS=jouw-app-wachtwoord

FOUNDER_EMAIL=jouw@email.com
NEXTENABLER_EMAIL=info@nextenabler.com

# === TWILIO (optioneel, voor WhatsApp notificaties) ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# === NEXTENABLER ATTRIBUTIE ===
NEXTENABLER_URL=https://nextenabler.com/scan
